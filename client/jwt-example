use serde::{Deserialize, Serialize};

#[derive(Debug, Serialize, Deserialize)]
pub struct Claims {
    pub sub: String,  // Optional. Subject, whom token refers to (user_id ou device_id?)
    pub role: String, // Custom field created by me
    pub aud: String,  // Optional. Audience (ex: payments-service)
    pub exp: usize, // Required. (validate_exp defaults to true in validation). Expiration time (as UTC timestamp)
    pub iat: usize, // Optional. Issued at (as UTC timestamp)
    pub jti: Uuid, // Optional. JWT ID, can be UUIDv4 (used when user logout and send request to server to invalidate this specific JWT)
}

impl Claims {
    pub fn new(sub: String, role: String, aud: String, exp: usize, iat: usize) -> Self {
        Claims {
            sub,
            role,
            aud,
            exp,
            iat,
            jti: Uuid::new_v4(),
        }
    }
}
